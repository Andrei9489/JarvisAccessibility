<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <solid android:color="#071426" />
            <stroke
                android:width="6dp"
                android:color="#0EA5E9" />
        </shape>
    </item>

    <item android:inset="16dp">
        <shape android:shape="oval">
            <solid android:color="#020817" />
            <stroke
                android:width="3dp"
                android:color="#22C55E" />
        </shape>
    </item>

    <item android:inset="38dp">
        <shape android:shape="oval">
            <solid android:color="#03111F" />
            <stroke
                android:width="2dp"
                android:color="#FACC15" />
        </shape>
    </item>

    <item android:inset="70dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="80dp"
                android:startColor="#0EA5E9"
                android:centerColor="#22C55E"
                android:endColor="#020817" />
        </shape>
    </item>

</layer-list>
